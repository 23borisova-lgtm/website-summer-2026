# Переменные окружения для функции /api/lead (заявки → AlfaCRM + MAX).
# ЭТО ШАБЛОН. Реальные значения вписываются НЕ сюда, а в Vercel:
#   Vercel → проект → Settings → Environment Variables (для Production).
# .env в git НЕ коммитим.

# --- AlfaCRM ---
ALFACRM_HOST=trikita.s20.online        # адрес вашей CRM (имя.s20.online)
ALFACRM_EMAIL=                         # e-mail сотрудника в AlfaCRM
ALFACRM_API_KEY=                       # ключ API: Настройки → Интеграции → API
ALFACRM_BRANCH=1                       # id филиала (обычно 1)
ALFACRM_LEAD_SOURCE_ID=                # (необязательно) id источника "Сайт", если хотите помечать

# --- MAX (уведомление админу) ---
MAX_BOT_TOKEN=                         # токен бота из @MasterBot в MAX
MAX_ADMIN_USER_ID=                     # ваш user_id в MAX (кому слать заявки)
# либо вместо user_id — id группового чата:
# MAX_ADMIN_CHAT_ID=
